{
  "name": "waiter-shift-tracker",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start:dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "prepare": "husky && allow-scripts",
    "install:secure": "npm ci --ignore-scripts && npm exec allow-scripts run"
  },
  "dependencies": {
    "@mantine/charts": "9.2.0",
    "@mantine/core": "9.2.0",
    "@mantine/dates": "9.2.0",
    "@mantine/form": "9.2.1",
    "@mantine/hooks": "9.2.0",
    "@mantine/notifications": "9.2.0",
    "@tabler/icons-react": "3.44.0",
    "dayjs": "1.11.20",
    "i18next": "26.1.0",
    "idb-keyval": "6.2.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-i18next": "17.0.7",
    "react-router-dom": "7.15.0",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@lavamoat/allow-scripts": "5.0.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.3.3",
    "@vitest/ui": "2.1.1",
    "fake-indexeddb": "6.0.0",
    "happy-dom": "20.9.0",
    "husky": "9.1.7",
    "jsdom": "27.0.1",
    "postcss": "8.5.14",
    "postcss-preset-mantine": "1.18.0",
    "typescript": "5.6.2",
    "vite": "5.4.10",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "2.1.1"
  },
  "lavamoat": {
    "allowScripts": {
      "vite>esbuild#0.21.5": true
    }
  }
